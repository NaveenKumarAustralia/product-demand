generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model SupplierOrder {
  id           Int         @id @default(autoincrement())
  shop         String
  poNumber     String?
  supplier     String
  productId    String
  productTitle String
  status          String    @default("open")
  supplierStatus  String    @default("on_order")
  supplierNotes   String?
  factoryNotes    String?
  priority        String?
  productImageUrl String?
  eta             DateTime?
  notes           String?
  totalQty        Int       @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lines        OrderLine[]
}

model OrderLine {
  id           Int           @id @default(autoincrement())
  orderId      Int
  order        SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId    String
  variantTitle String
  sku          String?
  qtyOrdered   Int
  qtyReceived  Int           @default(0)
  costPrice    Float?
  createdAt    DateTime      @default(now())
}

model SupplierAccount {
  id           Int      @id @default(autoincrement())
  shop         String
  name         String
  email        String
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shop, email])
}

model PortalSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
