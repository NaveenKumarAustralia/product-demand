generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model SupplierOrder {
  id           Int         @id @default(autoincrement())
  shop         String
  poNumber     String?
  supplier     String
  productId    String
  productTitle String
  productType  String?
  status          String    @default("open")
  supplierStatus  String    @default("on_order")
  supplierNotes   String?
  factoryNotes    String?
  priority        String?
  productImageUrl String?
  eta             DateTime?
  destination     String?
  packingListId   Int?
  notes           String?
  totalQty        Int       @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lines        OrderLine[]
}

model OrderLine {
  id           Int           @id @default(autoincrement())
  orderId      Int
  order        SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId    String
  variantTitle String
  sku          String?
  qtyOrdered   Int
  qtyReceived  Int           @default(0)
  costPrice    Float?
  createdAt    DateTime      @default(now())
}

model SupplierAccount {
  id           Int      @id @default(autoincrement())
  shop         String
  name         String
  email        String
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shop, email])
}

model PortalSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortalMessage {
  id              Int       @id @default(autoincrement())
  userId          String
  userName        String
  // entityType + orderId + entityKey + field identify the cell this
  // message is attached to. entityType is "supplier_order" /
  // "collection_row" / "fabric_row" / "sample_iteration". orderId is
  // the parent record's integer id (SupplierOrder.id / Collection.id
  // etc.); entityKey is the sub-row id (Collection row uuid, fabric
  // row id) when the parent has multiple rows.
  orderId         Int
  field           String
  entityType      String    @default("supplier_order")
  entityKey       String?
  // Reply chain. Top-level message has parentMessageId = null.
  // Replies set parentMessageId to the message they're replying to.
  parentMessageId Int?
  editedAt        DateTime?
  fromName        String?
  productTitle    String?
  body            String
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId, readAt, createdAt])
  @@index([orderId, field])
  @@index([entityType, orderId, entityKey, field])
  @@index([parentMessageId])
}

model PackingList {
  id                       Int               @id @default(autoincrement())
  title                    String
  invoiceNumber            String?
  shipmentDate             DateTime?
  expectedLeaveFactoryDate DateTime?
  shippingMethod           String?
  status                   String            @default("still_packing")
  notes                    String?
  hiddenAt                 DateTime?
  masterInventoryLoadedAt  DateTime?
  lockedFxRate             Float?
  lockedFxRateAt           DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  lines                    PackingListLine[]
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userName   String   @default("Unknown")
  action     String
  entity     String
  entityId   String?
  entityName String?
  field      String?
  toValue    String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model PackingListLine {
  id              Int         @id @default(autoincrement())
  packingListId   Int
  packingList     PackingList @relation(fields: [packingListId], references: [id], onDelete: Cascade)
  boxNumber       String?
  productId       String?
  productTitle    String
  productImageUrl String?
  fabricImageData String?
  sku             String?
  isCustom        Boolean     @default(false)
  qtys            Json        @default("{}")
  shopifyLoadedQtys Json      @default("{}")
  manuallyLoadedQtys Json     @default("{}")
  priceRupees     Float?
  weight          Float?
  notes           String?
  sortOrder       Int         @default(0)
  costPushedAt    DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Sample {
  id         Int               @id @default(autoincrement())
  name       String
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  iterations SampleIteration[]
}

model VisionBoard {
  id        Int              @id @default(autoincrement())
  name      String
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  items     VisionBoardItem[]
}

model VisionBoardItem {
  id        Int          @id @default(autoincrement())
  boardId   Int
  board     VisionBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name      String       @default("")
  sortOrder Int          @default(0)
  images    Json         @default("[]")
  thumbnail String?
  fields    Json         @default("[]")
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

// Faster, isolated copy of the vision board. Data is seeded from VisionBoard
// on first visit. Same JSONB-backed image storage but a slimmer loader path,
// memoized rendering, and higher-quality client-side compression on upload.
model VisionBoardV2 {
  id        Int                  @id @default(autoincrement())
  name      String
  sortOrder Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  items     VisionBoardV2Item[]
}

model VisionBoardV2Item {
  id        Int           @id @default(autoincrement())
  boardId   Int
  board     VisionBoardV2 @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name      String        @default("")
  sortOrder Int           @default(0)
  images    Json          @default("[]")
  thumbnail String?
  fields    Json          @default("[]")
  notes     String?
  status    String        @default("under_consideration")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([boardId, sortOrder])
}

model Collection {
  id        Int      @id @default(autoincrement())
  name      String   @default("Untitled collection")
  sortOrder Int      @default(0)
  thumbnail String?
  columns   Json     @default("[]")
  rows      Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Photo shoot briefs. Products are copied here from collections (the
// originals stay in the collection). Rows hold the styling/pairing
// fields and image cells, same JSON shape as Collection.rows.
model PhotoShoot {
  id        Int      @id @default(autoincrement())
  name      String   @default("Untitled shoot")
  sortOrder Int      @default(0)
  thumbnail String?
  rows      Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Full-quality image bytes for collection rows. Row JSON stores a
// compact { thumb, key } reference per image; this table holds the
// original bytes that get lazy-loaded when the popup opens and
// uploaded as-is to Shopify on push. Keeps the rows JSON small so
// get_collection_full stays fast.
model CollectionImage {
  key          String   @id              // uuid
  collectionId Int                       // for orphan cleanup later
  mimeType     String
  bytes        Bytes
  createdAt    DateTime @default(now())

  @@index([collectionId])
}

model SampleIteration {
  id          Int      @id @default(autoincrement())
  sampleId    Int
  sample      Sample   @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  version     Int
  name        String?
  notes       String?
  fabricType  String?
  sampleSize  String?
  buttonType  String?
  factoryCost String?
  status      String   @default("under_consideration")
  images      Json     @default("[]")
  thumbnail   String?
  taggedUsers Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
