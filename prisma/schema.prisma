generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model SupplierOrder {
  id           Int         @id @default(autoincrement())
  shop         String
  poNumber     String?
  supplier     String
  productId    String
  productTitle String
  productType  String?
  status          String    @default("open")
  supplierStatus  String    @default("on_order")
  supplierNotes   String?
  factoryNotes    String?
  priority        String?
  productImageUrl String?
  eta             DateTime?
  notes           String?
  totalQty        Int       @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lines        OrderLine[]
}

model OrderLine {
  id           Int           @id @default(autoincrement())
  orderId      Int
  order        SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId    String
  variantTitle String
  sku          String?
  qtyOrdered   Int
  qtyReceived  Int           @default(0)
  costPrice    Float?
  createdAt    DateTime      @default(now())
}

model SupplierAccount {
  id           Int      @id @default(autoincrement())
  shop         String
  name         String
  email        String
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shop, email])
}

model PortalSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortalMessage {
  id           Int       @id @default(autoincrement())
  userId       String
  userName     String
  orderId      Int
  field        String
  fromName     String?
  productTitle String?
  body         String
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, readAt, createdAt])
  @@index([orderId, field])
}

model PackingList {
  id                       Int               @id @default(autoincrement())
  title                    String
  invoiceNumber            String?
  shipmentDate             DateTime?
  expectedLeaveFactoryDate DateTime?
  status                   String            @default("still_packing")
  notes                    String?
  hiddenAt                 DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  lines                    PackingListLine[]
}

model PackingListLine {
  id              Int         @id @default(autoincrement())
  packingListId   Int
  packingList     PackingList @relation(fields: [packingListId], references: [id], onDelete: Cascade)
  boxNumber       String?
  productId       String?
  productTitle    String
  productImageUrl String?
  fabricImageData String?
  sku             String?
  isCustom        Boolean     @default(false)
  qtys            Json        @default("{}")
  priceRupees     Float?
  weight          Float?
  notes           String?
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
